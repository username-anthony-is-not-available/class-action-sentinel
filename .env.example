# Database
DATABASE_URL=postgres://sentinel:sentinel@postgres:5432/sentinel

# AI Provider — supports OpenAI, OpenRouter, or any OpenAI-compatible API
# For OpenAI (default): just set OPENAI_API_KEY
OPENAI_API_KEY=sk-your-key-here
# For OpenRouter: set all three below instead
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_API_KEY=sk-or-your-key-here
# AI_MODEL=google/gemini-2.0-flash-001

# Scraper
SCRAPE_SCHEDULE=0 3 1 * *

# Backend
PORT=3001
NODE_ENV=production
